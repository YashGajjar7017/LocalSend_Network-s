{
  "name": "local-network-share",
  "version": "1.0.0",
  "description": "Secure cross-platform local network file sharing desktop app",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron-build": "vite build",
    "preview": "vite preview",
    "electron-start": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"npm run electron-start\"",
    "dist": "npm run electron-build && electron-builder",
    "electron-pack": "npm run electron-build && electron-builder --dir"
  },
  "build": {
    "appId": "com.airsync.app",
    "productName": "AirSync",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "server/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "msi"
      ]
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "cors": "^2.8.5",
    "electron-is-dev": "^2.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.11"
  }
}
